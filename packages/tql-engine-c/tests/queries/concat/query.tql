#language 'typescript'

fn main() {
  (
    * > class_declaration {
      @class_name <- .name;
      text_eq(@class_name, 'SpecificClassName');
    }
  ) ++ (
    * > class_declaration {
      @decorator_name <- .decorator > call_expression.function;
      text_eq(@decorator_name, 'Foo');
    }
  )
}
