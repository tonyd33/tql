# https://just.systems
# vim: noexpandtab tabstop=4 shiftwidth=4

set shell := ["bash", "-euo", "pipefail", "-c"]

default:
	@just --list

build:
	pnpm build

watch:
	pnpm watch

serve: build
	python -m http.server 8000 -d public/

dev:
	pnpm watch & python -m http.server 8000 -d public/

clean:
	rm -rf node_modules public/bundle.js public/bundle.js.map public/tql.wasm
