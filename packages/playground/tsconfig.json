{
  "compilerOptions": {
    "rootDir": "./src",
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "lib": ["dom", "esnext"],
    "types": [],
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["src/**/*", "rolldown.config.mjs"]
}
