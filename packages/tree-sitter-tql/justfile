# https://just.systems
# vim: noexpandtab tabstop=4 shiftwidth=4

set shell := ["bash", "-euo", "pipefail", "-c"]
ts := "pnpm exec tree-sitter"

default:
	@just --list

generate:
	{{ts}} generate

build: generate
	{{ts}} build
	{{ts}} build --wasm

test:
	{{ts}} test

parse *args:
	{{ts}} parse {{args}}

playground:
	{{ts}} build --wasm
	{{ts}} playground

make *args:
	make {{args}}

clean:
	make clean
	rm -rf build *.wasm

