# https://just.systems
# vim: noexpandtab tabstop=4 shiftwidth=4

set shell := ["bash", "-euo", "pipefail", "-c"]

default:
	@just --list

build *args="-Dwasm=true":
	zig build {{ args }}

release:
	zig build -Doptimize=ReleaseFast --release=fast

[arg("update-snapshot", long="update-snapshot", value="true")]
test update-snapshot="false":
	zig build test -Dupdate-snapshots={{ update-snapshot }}

run *args:
	zig build run -- {{ args }}

fmt:
	zig fmt src build.zig

clean:
	rm -rf zig-out .zig-cache
