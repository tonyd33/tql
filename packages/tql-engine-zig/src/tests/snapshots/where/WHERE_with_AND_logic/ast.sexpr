(source_file (query_body (with (binding (child root (node class_declaration)) c) (binding (field c name) class_name) (binding (field c body) body) (binding (child body (node method_definition)) method_def) (binding (field method_def name) method_name)) (where (and (eq class_name (string "Service")) (eq method_name (string "foo")))) (select c)))